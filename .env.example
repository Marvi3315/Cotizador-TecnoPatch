# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ── Syscom proxy ──────────────────────────────────────────────
# En Netlify: la función /functions/syscom.js ya está lista.
# El redirect /api/syscom → /.netlify/functions/syscom está en netlify.toml
# Solo necesitas agregar estas variables en Netlify > Site Settings > Env Vars:
SYSCOM_CLIENT_ID=tu_client_id_de_syscom
SYSCOM_CLIENT_SECRET=tu_client_secret_de_syscom

# ── Opcional: override del proxy (para desarrollo local con proxy diferente) ──
# VITE_SYSCOM_PROXY=/api/syscom
